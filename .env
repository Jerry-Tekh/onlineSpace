# Filename: .env
# Vite projects require public env vars to be prefixed with VITE_
# Use .env.local (ignored) for secrets and local overrides

VITE_APP_NAME="myspace"
VITE_API_URL="https://api.example.com"
VITE_PUBLIC_PATH="/"
VITE_SENTRY_DSN=""

# NODE_ENV is set by the build tool, but can be specified for clarity
NODE_ENV=development
